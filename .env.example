# Copy this to .env and fill in the values.
# .env is git-ignored. .env.example is committed.

# Django
DJANGO_SECRET_KEY=replace-me-with-a-real-secret-key
DATABASE_URL=postgres://postgres:postgres@localhost:5432/frikkinwave

# Production only
ALLOWED_HOSTS=api.frikkinwave.com,frikkinwave.fly.dev
CORS_ALLOWED_ORIGINS=https://frikkinwave.com,https://www.frikkinwave.com

# Email (production)
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@frikkinwave.com

# OpenAI (Phase 2)
OPENAI_API_KEY=sk-...
# Semantic-search similarity floor (0..1): drop results scoring below this.
# 0.0 disables the floor. NOTE: cosine similarities from text-embedding-3-small
# are typically low even for related text, so high values return few results.
SEARCH_SIMILARITY_THRESHOLD=0.8

# Redis / Celery (Phase 2)
CELERY_BROKER_URL=redis://localhost:6379/0
