# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Fly.io
fly.toml.bak

# Terraform — state can contain secrets; never commit it.
# (.terraform.lock.hcl IS committed for reproducible provider versions.)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# Saved plans embed variable values (incl. secrets) — never commit.
tfplan
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
